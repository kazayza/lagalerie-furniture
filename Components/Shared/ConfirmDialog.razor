@using MudBlazor
@using Microsoft.AspNetCore.Components

<MudDialog Style="background: var(--surface-dark); border: 1px solid var(--border-color); border-radius: 12px;">
    <DialogContent>
        <MudText Typo="Typo.body1" Style="color: var(--text-primary);">@Message</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@NoText</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="Confirm">@YesText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string Message { get; set; } = "هل أنت متأكد؟";
    [Parameter] public string YesText { get; set; } = "تأكيد";
    [Parameter] public string NoText { get; set; } = "إلغاء";

    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
