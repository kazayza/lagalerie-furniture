@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using LagalerieFurniture.Services
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject UserInfoService UserInfoService
@inject ThemeService ThemeService
@inject IMenuService MenuService
@inject IAuthService AuthService
@inject ILogger<TopHeader> Logger

<MudAppBar Elevation="0" Class="glass-appbar" Style="height: 68px;">
    <div class="appbar-inner">
        @* القسم الأيمن *@
        <div class="appbar-left">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                          OnClick="ToggleDrawer"
                          Color="Color.Inherit"
                          Class="appbar-menu-btn" />

            <div class="appbar-brand">
                <span class="appbar-brand-logo" role="img" aria-label="Lagalerie"></span>
                <span class="appbar-brand-text">Lagalerie</span>
            </div>

            <div class="appbar-breadcrumbs">
                <MudText Typo="Typo.body2" Class="breadcrumb-text">@GetBreadcrumbText()</MudText>
            </div>
        </div>

        @* القسم الأيسر *@
        <div class="appbar-right">
            <div class="appbar-search-wrapper">
                <MudTextField T="string" @bind-Value="_searchQuery"
                             Placeholder="بحث سريع..."
                             Variant="Variant.Outlined"
                             Class="appbar-search"
                             InputType="InputType.Search"
                             AdornmentIcon="@Icons.Material.Filled.Search"
                             Adornment="Adornment.Start" />
            </div>

            <MudTooltip Text="البريد الداخلي">
                <div class="notification-btn-wrapper" @onclick="GoToMail">
                    <MudIconButton Icon="@Icons.Material.Filled.MarkEmailUnread"
                                  Color="Color.Inherit"
                                  Class="appbar-icon-btn mail-icon-btn" />
                    @if (_mailCount > 0)
                    {
                        <span class="notification-pulse"></span>
                        <span class="notification-badge mail">@_mailCount</span>
                    }
                </div>
            </MudTooltip>

            <MudTooltip Text="الإشعارات">
                <div class="notification-btn-wrapper">
                    <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                                  Color="Color.Inherit"
                                  Class="appbar-icon-btn" />
                    @if (_notificationCount > 0)
                    {
                        <span class="notification-pulse"></span>
                        <span class="notification-badge">@_notificationCount</span>
                    }
                </div>
            </MudTooltip>

            <MudTooltip Text="@(_isDarkMode ? "الوضع النهاري" : "الوضع الليلي")">
                <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                              OnClick="ToggleTheme"
                              Color="Color.Inherit"
                              Class="appbar-icon-btn theme-toggle-btn" />
            </MudTooltip>

            <MudTooltip Text="تسجيل الخروج">
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                              OnClick="Logout"
                              Color="Color.Error"
                              Class="appbar-icon-btn" />
            </MudTooltip>

            @if (_isAuthenticated)
            {
                <div class="user-dropdown-host">
                    <button type="button"
                            class="user-menu-trigger premium-user-trigger"
                            aria-haspopup="true"
                            aria-expanded="@_isUserMenuOpen"
                            @onclick="ToggleUserMenu">
                        <div class="user-avatar-wrapper">
                            @if (!string.IsNullOrWhiteSpace(_avatarUrl))
                            {
                                <img src="@_avatarUrl" class="topbar-user-photo" alt="@_currentUsername" />
                            }
                            else
                            {
                                <div class="topbar-user-photo fallback">@GetInitials(_currentUsername)</div>
                            }
                            <div class="user-status-dot"></div>
                        </div>
                        <div class="user-info-text">
                            <span class="user-display-name">@_currentUsername</span>
                            <span class="user-role-badge">@_userRole</span>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Class="user-dropdown-icon" />
                    </button>

                    @if (_isUserMenuOpen)
                    {
                        <div class="premium-user-dropdown-panel">
                            <div class="premium-user-menu-header">
                                <div class="user-avatar-wrapper big">
                                    @if (!string.IsNullOrWhiteSpace(_avatarUrl))
                                    {
                                        <img src="@_avatarUrl" class="topbar-user-photo big" alt="@_currentUsername" />
                                    }
                                    else
                                    {
                                        <div class="topbar-user-photo big fallback">@GetInitials(_currentUsername)</div>
                                    }
                                    <div class="user-status-dot"></div>
                                </div>
                                <div>
                                    <div class="premium-user-name">@_currentUsername</div>
                                    <div class="premium-user-role">@_userRole</div>
                                </div>
                            </div>

                            <div class="premium-user-menu-divider"></div>

                            <button type="button" class="premium-user-menu-item" @onclick="GoToProfile">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                <span>الملف الشخصي</span>
                            </button>
                            <button type="button" class="premium-user-menu-item" @onclick="GoToMail">
                                <MudIcon Icon="@Icons.Material.Filled.Mail" Size="Size.Small" />
                                <span>البريد الداخلي</span>
                            </button>
                            <button type="button" class="premium-user-menu-item" @onclick="GoToSettings">
                                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" />
                                <span>الإعدادات</span>
                            </button>

                            <div class="premium-user-menu-divider"></div>

                            <button type="button" class="premium-user-menu-item danger" @onclick="Logout">
                                <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" />
                                <span>تسجيل الخروج</span>
                            </button>
                        </div>
                    }
                </div>
            }
            else
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToLogin"
                           StartIcon="@Icons.Material.Filled.Login">
                    دخول
                </MudButton>
            }
        </div>
    </div>
</MudAppBar>

@code {
    [Parameter] public EventCallback ToggleDrawerCallback { get; set; }

    private string _currentUsername = "مستخدم";
    private string _userRole = "";
    private bool _isAuthenticated = false;
    private bool _isDarkMode = true;
    private bool _isUserMenuOpen = false;
    private int _notificationCount = 0;
    private int _mailCount = 0;
    private string _searchQuery = string.Empty;
    private string? _avatarUrl;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            _isAuthenticated = user.Identity?.IsAuthenticated == true;
            _currentUsername = user.FindFirst(ClaimTypes.GivenName)?.Value ?? user.Identity?.Name ?? "مستخدم";
            _userRole = user.FindFirst(ClaimTypes.Role)?.Value ?? "";
            _avatarUrl = user.FindFirst("avatar")?.Value;

            if (!_isAuthenticated)
            {
                var userInfo = await UserInfoService.GetCurrentUserAsync();
                if (userInfo != null)
                {
                    _isAuthenticated = true;
                    _currentUsername = userInfo.DisplayName ?? userInfo.Username ?? "مستخدم";
                    _userRole = userInfo.Role ?? "";
                    _avatarUrl = userInfo.AvatarUrl;
                }
            }

            if (_isAuthenticated)
            {
                var userInfo = await UserInfoService.GetCurrentUserAsync();
                var userId = userInfo?.UserId ?? 0;
                if (userId > 0)
                {
                    _notificationCount = await MenuService.GetUnreadNotificationCountAsync(userId);
                    _mailCount = 0; // TODO: يتم ربطه لاحقاً بخدمة البريد الداخلي
                    if (string.IsNullOrWhiteSpace(_avatarUrl))
                        _avatarUrl = userInfo?.AvatarUrl;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[TopHeader] فشل تحميل حالة المصادقة");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await ThemeService.IsDarkModeAsync();
            await ThemeService.ApplyThemeClassAsync(_isDarkMode);
            StateHasChanged();
        }
    }

    private void ToggleDrawer() => ToggleDrawerCallback.InvokeAsync();

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        await ThemeService.SetDarkModeAsync(_isDarkMode);
        await ThemeService.ApplyThemeClassAsync(_isDarkMode);
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private void ToggleUserMenu() => _isUserMenuOpen = !_isUserMenuOpen;
    private void CloseUserMenu() => _isUserMenuOpen = false;

    private void GoToLogin() => Navigation.NavigateTo("/login", forceLoad: true);

    private void GoToProfile()
    {
        CloseUserMenu();
        Navigation.NavigateTo("/profile");
    }

    private void GoToSettings()
    {
        CloseUserMenu();
        Navigation.NavigateTo("/settings");
    }

    private void GoToMail()
    {
        CloseUserMenu();
        Navigation.NavigateTo("/mail");
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length > 1 ? $"{parts[0][0]}{parts[1][0]}" : name[..1];
    }

    private string GetBreadcrumbText()
    {
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (string.IsNullOrEmpty(uri) || uri == "/") return "لوحة التحكم";

        var segments = uri.Split('/', StringSplitOptions.RemoveEmptyEntries);
        var breadcrumbs = segments.Select(s => s switch
        {
            "users" => "المستخدمون", "roles" => "الأدوار",
            "invoices" => "الفواتير", "customers" => "العملاء",
            "orders" => "الطلبات", "inventory" => "المخزون",
            "production-orders" => "أوامر الإنتاج", "reports" => "التقارير",
            "settings" => "الإعدادات", "profile" => "الملف الشخصي",
            "create" => "جديد", "edit" => "تعديل",
            _ => s
        });
        return "الرئيسية › " + string.Join(" › ", breadcrumbs);
    }
}