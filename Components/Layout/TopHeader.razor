@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using LagalerieFurniture.Services
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject UserInfoService UserInfoService
@inject ThemeService ThemeService
@inject IMenuService MenuService
@inject IAuthService AuthService
@inject ILogger<TopHeader> Logger

<MudAppBar Elevation="0" Class="glass-appbar" Style="height: 68px;">
    <div class="appbar-inner">
        @* القسم الأيمن *@
        <div class="appbar-left">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                          OnClick="ToggleDrawer"
                          Color="Color.Inherit"
                          Class="appbar-menu-btn" />

            <div class="appbar-brand">
                <span class="appbar-brand-icon">🪑</span>
                <span class="appbar-brand-text">Lagalerie</span>
            </div>

            <div class="appbar-breadcrumbs">
                <MudText Typo="Typo.body2" Class="breadcrumb-text">@GetBreadcrumbText()</MudText>
            </div>
        </div>

        @* القسم الأيسر *@
        <div class="appbar-right">
            <div class="appbar-search-wrapper">
                <MudTextField T="string" @bind-Value="_searchQuery"
                             Placeholder="بحث سريع..."
                             Variant="Variant.Outlined"
                             Class="appbar-search"
                             InputType="InputType.Search"
                             AdornmentIcon="@Icons.Material.Filled.Search"
                             Adornment="Adornment.Start" />
            </div>

            <div class="notification-btn-wrapper">
                <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                              Color="Color.Inherit"
                              Class="appbar-icon-btn" />
                @if (_notificationCount > 0)
                {
                    <span class="notification-pulse"></span>
                    <span class="notification-badge">@_notificationCount</span>
                }
            </div>

            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                          OnClick="ToggleTheme"
                          Color="Color.Inherit"
                          Class="appbar-icon-btn theme-toggle-btn" />

            <MudTooltip Text="تسجيل الخروج">
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                              OnClick="Logout"
                              Color="Color.Error"
                              Class="appbar-icon-btn" />
            </MudTooltip>

            @if (_isAuthenticated)
            {
                <MudMenu Class="user-menu-wrapper" Anchor="Origin.BottomLeft">
                    <ActivatorContent>
                        <div class="user-menu-trigger">
                            <div class="user-avatar-wrapper">
                                <MudAvatar Class="user-avatar" Size="Size.Small" Style="background: var(--primary-gold); color: #000;">
                                    @(GetInitials(_currentUsername))
                                </MudAvatar>
                                <div class="user-status-dot"></div>
                            </div>
                            <div class="user-info-text">
                                <span class="user-display-name">@_currentUsername</span>
                                <span class="user-role-badge">@_userRole</span>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Size="Size.Small" Class="user-dropdown-icon" />
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                        <div class="user-menu-header" Style="padding: 16px; display: flex; gap: 12px; align-items: center;">
                            <MudAvatar Size="Size.Medium" Style="background: var(--primary-gold); color: #000;">
                                @(GetInitials(_currentUsername))
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle2">@_currentUsername</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@_userRole</MudText>
                            </div>
                        </div>
                        <MudDivider />
                        <MudMenuItem OnClick="GoToProfile" Icon="@Icons.Material.Filled.Person">الملف الشخصي</MudMenuItem>
                        <MudMenuItem OnClick="GoToSettings" Icon="@Icons.Material.Filled.Settings">الإعدادات</MudMenuItem>
                        <MudDivider />
                        <MudMenuItem OnClick="Logout" Icon="@Icons.Material.Filled.Logout" Style="color: var(--error);">تسجيل الخروج</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            }
            else
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToLogin"
                           StartIcon="@Icons.Material.Filled.Login">
                    دخول
                </MudButton>
            }
        </div>
    </div>
</MudAppBar>

@code {
    [Parameter] public EventCallback ToggleDrawerCallback { get; set; }

    private string _currentUsername = "مستخدم";
    private string _userRole = "";
    private bool _isAuthenticated = false;
    private bool _isDarkMode = true;
    private int _notificationCount = 0;
    private string _searchQuery = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            _isAuthenticated = user.Identity?.IsAuthenticated == true;
            _currentUsername = user.FindFirst(ClaimTypes.GivenName)?.Value ?? user.Identity?.Name ?? "مستخدم";
            _userRole = user.FindFirst(ClaimTypes.Role)?.Value ?? "";

            if (!_isAuthenticated)
            {
                var userInfo = await UserInfoService.GetCurrentUserAsync();
                if (userInfo != null)
                {
                    _isAuthenticated = true;
                    _currentUsername = userInfo.DisplayName ?? userInfo.Username ?? "مستخدم";
                    _userRole = userInfo.Role ?? "";
                }
            }

            if (_isAuthenticated)
            {
                var userInfo = await UserInfoService.GetCurrentUserAsync();
                var userId = userInfo?.UserId ?? 0;
                if (userId > 0)
                {
                    _notificationCount = await MenuService.GetUnreadNotificationCountAsync(userId);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[TopHeader] فشل تحميل حالة المصادقة");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await ThemeService.IsDarkModeAsync();
            StateHasChanged();
        }
    }

    private void ToggleDrawer() => ToggleDrawerCallback.InvokeAsync();

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        await ThemeService.SetDarkModeAsync(_isDarkMode);
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private void GoToLogin() => Navigation.NavigateTo("/login", forceLoad: true);
    private void GoToProfile() => Navigation.NavigateTo("/profile");
    private void GoToSettings() => Navigation.NavigateTo("/settings");

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length > 1 ? $"{parts[0][0]}{parts[1][0]}" : name[..1];
    }

    private string GetBreadcrumbText()
    {
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (string.IsNullOrEmpty(uri) || uri == "/") return "لوحة التحكم";

        var segments = uri.Split('/', StringSplitOptions.RemoveEmptyEntries);
        var breadcrumbs = segments.Select(s => s switch
        {
            "users" => "المستخدمون", "roles" => "الأدوار",
            "invoices" => "الفواتير", "customers" => "العملاء",
            "orders" => "الطلبات", "inventory" => "المخزون",
            "production-orders" => "أوامر الإنتاج", "reports" => "التقارير",
            "settings" => "الإعدادات", "profile" => "الملف الشخصي",
            "create" => "جديد", "edit" => "تعديل",
            _ => s
        });
        return "الرئيسية › " + string.Join(" › ", breadcrumbs);
    }
}