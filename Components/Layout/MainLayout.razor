@using MudBlazor
@using LagalerieFurniture.Services
@using System.Linq
@using System.Security.Claims
@inject IAuthService AuthService
@inject UserInfoService UserInfoService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ThemeService ThemeService
@inject IMenuService MenuService
@inject ILogger<MainLayout> Logger
@inherits LayoutComponentBase

@if (!_authChecked)
{
    <div class="loading-overlay">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.body1" Class="mt-4" Style="color: var(--primary-gold);">جاري تحميل النظام...</MudText>
    </div>
}
else
{
    <MudThemeProvider @bind-IsDarkMode="_isDarkMode" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <MudRTLProvider>
        <MudLayout>
            <TopHeader ToggleDrawerCallback="ToggleDrawer" />

            <MudDrawer @bind-Open="_drawerOpen"
                       Variant="DrawerVariant.Responsive"
                       ClipMode="DrawerClipMode.Always"
                       Elevation="0"
                       Anchor="Anchor.End"
                       Width="280px"
                       Class="glass-drawer">
                <SidebarMenu @bind-IsMiniMode="_isMiniMode" />
            </MudDrawer>

            <MudMainContent Class="main-content-area">
                <div class="main-content-inner">
                    @Body
                </div>
            </MudMainContent>
        </MudLayout>
    </MudRTLProvider>
}

@code {
    private string _currentUsername = string.Empty;
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private bool _isMiniMode = false;
    private bool _authChecked = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            bool isAuthenticated = user.Identity?.IsAuthenticated == true;

            if (!isAuthenticated)
            {
                var userInfo = await UserInfoService.GetCurrentUserAsync();
                if (userInfo != null)
                {
                    isAuthenticated = true;
                    _currentUsername = userInfo.DisplayName ?? userInfo.Username ?? "مستخدم";
                }
            }
            else
            {
                _currentUsername = user.FindFirst(ClaimTypes.GivenName)?.Value
                                 ?? user.Identity?.Name
                                 ?? "مستخدم";
            }

            if (!isAuthenticated)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            _authChecked = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[MainLayout] فشل في OnInitializedAsync");
            _authChecked = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await ThemeService.IsDarkModeAsync();
            _isMiniMode = await MenuService.GetSidebarMiniModeAsync();
            StateHasChanged();
        }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}