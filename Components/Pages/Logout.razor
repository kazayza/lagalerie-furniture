@page "/logout"
@inject NavigationManager Navigation

<PageTitle>تسجيل الخروج</PageTitle>

@code {
    protected override void OnInitialized()
    {
        // التنقل لـ endpoint اللي يمسح الـ cookie (HTTP request جديد)
        // forceLoad = true عشان الـ circuit يتكسر ويتعمل جديد بدون auth
        Navigation.NavigateTo("/api/auth/logout", forceLoad: true);
    }
}
