@using LagalerieFurniture.Models
<MudDialog Style="background: var(--surface-dark); border: 1px solid var(--border-color); border-radius: 12px;">
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            كلمة المرور الجديدة للمستخدم: <strong>@DisplayName</strong>
        </MudText>
        <MudTextField @bind-Value="_password"
                      Label="كلمة المرور"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      Immediate="true"
                      Validation="@ValidatePassword">
            <MudIcon Icon="@Icons.Material.Filled.Lock" />
        </MudTextField>
        <MudTextField @bind-Value="_confirm"
                      Label="تأكيد كلمة المرور"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      Immediate="true"
                      Class="mt-2"
                      Validation="@ValidateConfirm">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" />
        </MudTextField>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">إلغاء</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(_password != _confirm || _password.Length < 6)">
            تعيين
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int UserId { get; set; }
    [Parameter] public string DisplayName { get; set; } = string.Empty;

    private string _password = string.Empty;
    private string _confirm = string.Empty;

    private IEnumerable<string> ValidatePassword(string v)
    {
        if (string.IsNullOrWhiteSpace(v)) yield return "مطلوبة";
        else if (v.Length < 6) yield return "6 أحرف على الأقل";
    }
    private IEnumerable<string> ValidateConfirm(string v)
    {
        if (v != _password) yield return "غير مطابقة";
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(_password));
    private void Cancel() => MudDialog.Cancel();
}
