@page "/users"
@using LagalerieFurniture.Models
@using LagalerieFurniture.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Policy = "USR_VIEW")]
@inject IUserService UserService
@inject IRoleService RoleService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>المستخدمون - Lagalerie</PageTitle>

<div class="users-page-shell">
    <section class="users-hero-panel">
        <div class="users-hero-content">
            <div class="users-kicker">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" />
                مركز الأمان والصلاحيات
            </div>
            <h1>إدارة المستخدمين</h1>
            <p>تحكم كامل في حسابات النظام، حالات الدخول، الأدوار، والاستثناءات الأمنية من شاشة واحدة.</p>
            <div class="users-hero-actions">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshAsync" Disabled="_loading">
                    تحديث
                </MudButton>
                @if (_currentUser.HasPermission("USR_CREATE"))
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="OpenCreate">
                        مستخدم جديد
                    </MudButton>
                }
            </div>
        </div>
        <div class="users-hero-orb">
            <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" />
        </div>
    </section>

    <section class="security-stats-grid">
        <div class="security-stat-card total">
            <div class="stat-icon"><MudIcon Icon="@Icons.Material.Filled.Groups" /></div>
            <div>
                <span class="stat-label">إجمالي المستخدمين</span>
                <strong>@_result.TotalCount</strong>
            </div>
        </div>
        <div class="security-stat-card active">
            <div class="stat-icon"><MudIcon Icon="@Icons.Material.Filled.VerifiedUser" /></div>
            <div>
                <span class="stat-label">نشط في الصفحة</span>
                <strong>@_result.Items.Count(u => u.IsActive && !u.IsLocked)</strong>
            </div>
        </div>
        <div class="security-stat-card locked">
            <div class="stat-icon"><MudIcon Icon="@Icons.Material.Filled.Lock" /></div>
            <div>
                <span class="stat-label">حسابات مقفلة</span>
                <strong>@_result.Items.Count(u => u.IsLocked)</strong>
            </div>
        </div>
        <div class="security-stat-card roles">
            <div class="stat-icon"><MudIcon Icon="@Icons.Material.Filled.Badge" /></div>
            <div>
                <span class="stat-label">الأدوار المتاحة</span>
                <strong>@_roles.Count</strong>
            </div>
        </div>
    </section>

    <section class="users-toolbar-panel">
        <div class="toolbar-main-search">
            <MudTextField @bind-Value="_search"
                          Placeholder="ابحث باسم المستخدم، البريد، الاسم..."
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          OnKeyUp="OnSearchKeyUp" />
        </div>
        <div class="toolbar-filters">
            <MudSelect @bind-Value="_roleIdFilter" Label="الدور" Variant="Variant.Outlined" Clearable="true">
                @foreach (var role in _roles)
                {
                    <MudSelectItem Value="@role.Id">@role.DisplayName</MudSelectItem>
                }
            </MudSelect>
            <MudSelect @bind-Value="_activeFilter" Label="الحالة" Variant="Variant.Outlined" Clearable="true">
                <MudSelectItem Value="@true">نشط</MudSelectItem>
                <MudSelectItem Value="@false">معطّل</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FilterAlt" OnClick="Search" Disabled="_loading">
                تطبيق
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.RestartAlt" OnClick="ResetFilters" Disabled="_loading">
                إعادة ضبط
            </MudButton>
        </div>
    </section>

    <section class="users-data-panel">
        <div class="users-data-header">
            <div>
                <div class="panel-title-line">
                    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Primary" />
                    <span>قائمة المستخدمين</span>
                    <span class="panel-count">@_result.TotalCount</span>
                </div>
                <p>الصفحة @_selectedPage من @Math.Max(1, _result.TotalPages)</p>
            </div>
        </div>

        @if (_loading)
        {
            <div class="users-loading-list">
                @for (var i = 0; i < 6; i++)
                {
                    <div class="user-skeleton-row">
                        <div class="skeleton avatar"></div>
                        <div class="skeleton text wide"></div>
                        <div class="skeleton text"></div>
                        <div class="skeleton pill"></div>
                    </div>
                }
            </div>
        }
        else if (_result.Items.Count == 0)
        {
            <div class="users-empty-state">
                <div class="empty-icon"><MudIcon Icon="@Icons.Material.Filled.PersonSearch" /></div>
                <h3>لا توجد نتائج مطابقة</h3>
                <p>جرّب تغيير كلمات البحث أو إعادة ضبط الفلاتر.</p>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ResetFilters">إعادة ضبط الفلاتر</MudButton>
            </div>
        }
        else
        {
            <MudTable Items="@_result.Items" Hover="true" Elevation="0" Class="modern-users-table">
                <HeaderContent>
                    <MudTh>المستخدم</MudTh>
                    <MudTh>الدور</MudTh>
                    <MudTh>الحالة</MudTh>
                    <MudTh>آخر دخول</MudTh>
                    <MudTh>تاريخ الإنشاء</MudTh>
                    <MudTh Style="text-align: center;">إجراءات</MudTh>
                </HeaderContent>
                <RowTemplate Context="u">
                    <MudTd DataLabel="المستخدم">
                        <div class="user-identity-cell">
                            <div class="lux-avatar @(u.IsActive ? "" : "muted")">
                                @if (!string.IsNullOrWhiteSpace(u.AvatarUrl))
                                {
                                    <img src="@u.AvatarUrl" alt="@u.DisplayName" />
                                }
                                else
                                {
                                    @GetInitials(u.DisplayName)
                                }
                            </div>
                            <div class="user-text">
                                <strong>@u.DisplayName</strong>
                                <span>@@@u.Username</span>
                                <small>@u.Email</small>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="الدور">
                        <span class="role-badge">@(u.RoleDisplayName ?? u.RoleName)</span>
                    </MudTd>
                    <MudTd DataLabel="الحالة">
                        @if (!u.IsActive)
                        {
                            <span class="lux-status disabled"><i></i> معطّل</span>
                        }
                        else if (u.IsLocked)
                        {
                            <span class="lux-status locked"><i></i> مقفل</span>
                        }
                        else
                        {
                            <span class="lux-status active"><i></i> نشط</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="آخر دخول">
                        <span class="date-text">@(u.LastLoginAt.HasValue ? u.LastLoginAt.Value.ToLocalTime().ToString("yyyy/MM/dd HH:mm") : "لم يسجل بعد")</span>
                    </MudTd>
                    <MudTd DataLabel="تاريخ الإنشاء">
                        <span class="date-text">@u.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd")</span>
                    </MudTd>
                    <MudTd Style="text-align: center;" DataLabel="إجراءات">
                        <div class="users-inline-actions">
                            @if (_currentUser.HasPermission("USR_EDIT"))
                            {
                                <MudTooltip Text="تعديل">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Size="Size.Small"
                                                   Class="row-action-button"
                                                   OnClick="@(() => Edit(u))" />
                                </MudTooltip>
                                <MudTooltip Text="@(u.IsActive ? "تعطيل الحساب" : "تفعيل الحساب")">
                                    <MudIconButton Icon="@Icons.Material.Filled.PowerSettingsNew"
                                                   Size="Size.Small"
                                                   Class="row-action-button"
                                                   OnClick="@(() => ToggleActive(u))" />
                                </MudTooltip>
                                @if (u.IsLocked)
                                {
                                    <MudTooltip Text="فك القفل">
                                        <MudIconButton Icon="@Icons.Material.Filled.LockOpen"
                                                       Size="Size.Small"
                                                       Class="row-action-button"
                                                       OnClick="@(() => Unlock(u))" />
                                    </MudTooltip>
                                }
                            }

                            @if (_currentUser.HasPermission("USR_PERMISSIONS"))
                            {
                                <MudTooltip Text="الصلاحيات المباشرة">
                                    <MudIconButton Icon="@Icons.Material.Filled.AdminPanelSettings"
                                                   Size="Size.Small"
                                                   Class="row-action-button"
                                                   OnClick="@(() => Navigation.NavigateTo($"/users/{u.Id}/permissions"))" />
                                </MudTooltip>
                            }

                            @if (_currentUser.HasPermission("USR_RESET_PASSWORD"))
                            {
                                <MudTooltip Text="إعادة تعيين كلمة المرور">
                                    <MudIconButton Icon="@Icons.Material.Filled.Key"
                                                   Size="Size.Small"
                                                   Class="row-action-button"
                                                   OnClick="@(() => ResetPassword(u))" />
                                </MudTooltip>
                            }

                            @if (_currentUser.HasPermission("USR_DELETE"))
                            {
                                <MudTooltip Text="حذف">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   Class="row-action-button danger"
                                                   OnClick="@(() => Delete(u))" />
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            @if (_result.TotalCount > 0)
            {
                <div class="users-pagination-wrap">
                    <MudPagination Count="@Math.Max(1, _result.TotalPages)" Selected="@_selectedPage" OnSelected="OnPageChanged" />
                </div>
            }
        }
    </section>
</div>

@code {
    private ClaimsPrincipal _currentUser = new();
    private int _currentUserId;

    private string _search = string.Empty;
    private int? _roleIdFilter;
    private bool? _activeFilter;

    private PagedResult<UserListItemDto> _result = new() { Page = 1, PageSize = 20 };
    private List<Role> _roles = new();
    private bool _loading = true;
    private int _selectedPage = 1;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUser = state.User;
        _currentUserId = _currentUser.GetUserId() ?? 0;
        _roles = await RoleService.GetAllAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            var pageToLoad = Math.Max(1, _selectedPage);

            _result = await UserService.GetUsersAsync(new UserFilter
            {
                Search = string.IsNullOrWhiteSpace(_search) ? null : _search,
                RoleId = _roleIdFilter,
                IsActive = _activeFilter,
                Page = pageToLoad,
                PageSize = 20
            });

            _selectedPage = Math.Max(1, _result.Page);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ أثناء تحميل البيانات: {ex.Message}", Severity.Error);
            Console.WriteLine(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Search()
    {
        _selectedPage = 1;
        _result.Page = 1;
        await LoadData();
    }

    private async Task RefreshAsync() => await LoadData();

    private async Task ResetFilters()
    {
        _search = string.Empty;
        _roleIdFilter = null;
        _activeFilter = null;
        await Search();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await Search();
    }

    private async Task OnPageChanged(int page)
    {
        _selectedPage = page;
        _result.Page = page;
        await LoadData();
    }

    private void OpenCreate() => Navigation.NavigateTo("/users/new");
    private void Edit(UserListItemDto u) => Navigation.NavigateTo($"/users/{u.Id}/edit");

    private async Task ToggleActive(UserListItemDto u)
    {
        var (ok, err) = await UserService.ToggleActiveAsync(u.Id, _currentUserId);
        if (ok) { Snackbar.Add("تم تحديث حالة الحساب", Severity.Success); await LoadData(); }
        else Snackbar.Add(err ?? "فشل", Severity.Error);
    }

    private async Task Unlock(UserListItemDto u)
    {
        var (ok, err) = await UserService.UnlockAsync(u.Id, _currentUserId);
        if (ok) { Snackbar.Add("تم فك قفل الحساب", Severity.Success); await LoadData(); }
        else Snackbar.Add(err ?? "فشل", Severity.Error);
    }

    private async Task Delete(UserListItemDto u)
    {
        var parameters = new DialogParameters
        {
            ["Message"] = $"هل تريد حذف المستخدم «{u.DisplayName}»؟ هذا الإجراء يمكن التراجع عنه من قاعدة البيانات فقط.",
            ["YesText"] = "حذف",
            ["NoText"] = "إلغاء"
        };
        var dialog = await DialogService.ShowAsync<LagalerieFurniture.Components.Shared.ConfirmDialog>("تأكيد الحذف", parameters);
        var result = await dialog.Result;
        if (result?.Canceled ?? true) return;
        var (success, err) = await UserService.DeleteAsync(u.Id, _currentUserId);
        if (success) { Snackbar.Add("تم حذف المستخدم", Severity.Success); await LoadData(); }
        else Snackbar.Add(err ?? "فشل", Severity.Error);
    }

    private async Task ResetPassword(UserListItemDto u)
    {
        var parameters = new DialogParameters { ["UserId"] = u.Id, ["DisplayName"] = u.DisplayName };
        var dialog = await DialogService.ShowAsync<ResetPasswordDialog>($"إعادة تعيين كلمة المرور - {u.DisplayName}", parameters);
        var result = await dialog.Result;
        if (!(result?.Canceled ?? true))
        {
            var password = (string?)result?.Data;
            if (!string.IsNullOrEmpty(password))
            {
                var (ok, err) = await UserService.ResetPasswordAsync(u.Id, password, _currentUserId);
                if (ok) Snackbar.Add("تمت إعادة التعيين. سيُطلب من المستخدم تغييرها عند الدخول.", Severity.Success);
                else Snackbar.Add(err ?? "فشل", Severity.Error);
            }
        }
    }

    private static string GetInitials(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName)) return "U";
        var parts = displayName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpperInvariant();
        return string.Concat(parts.Take(2).Select(p => p[..1])).ToUpperInvariant();
    }
}
