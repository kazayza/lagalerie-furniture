@page "/"
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>الرئيسية - Lagalerie Furniture</PageTitle>

<MudGrid Spacing="3" Class="mb-6">
    <MudItem xs="12" sm="6" md="3">
        <div class="dashboard-card fade-in" style="animation-delay: 0ms;">
            <div class="dashboard-card-icon sales">
                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Large" />
            </div>
            <div class="dashboard-card-title">المبيعات اليوم</div>
            <div class="dashboard-card-value">24,580 ج.م</div>
            <div class="dashboard-card-trend trend-up">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                <span>+12.5%</span>
            </div>
        </div>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <div class="dashboard-card fade-in" style="animation-delay: 100ms;">
            <div class="dashboard-card-icon inventory">
                <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Large" />
            </div>
            <div class="dashboard-card-title">المنتجات بالمخزون</div>
            <div class="dashboard-card-value">1,248</div>
            <div class="dashboard-card-trend trend-up">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                <span>+3.2%</span>
            </div>
        </div>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <div class="dashboard-card fade-in" style="animation-delay: 200ms;">
            <div class="dashboard-card-icon production">
                <MudIcon Icon="@Icons.Material.Filled.Factory" Size="Size.Large" />
            </div>
            <div class="dashboard-card-title">أوامر الإنتاج</div>
            <div class="dashboard-card-value">18</div>
            <div class="dashboard-card-trend trend-down">
                <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Size="Size.Small" />
                <span>-2</span>
            </div>
        </div>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <div class="dashboard-card fade-in" style="animation-delay: 300ms;">
            <div class="dashboard-card-icon finance">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Large" />
            </div>
            <div class="dashboard-card-title">المستحقات</div>
            <div class="dashboard-card-value">45,200 ج.م</div>
            <div class="dashboard-card-trend trend-up">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                <span>+8.1%</span>
            </div>
        </div>
    <MudItem xs="12" md="4">
        <MudCard Elevation="0" Class="fade-in" Style="background: var(--surface-dark); border: 1px solid var(--border-glass);">
            <MudCardContent>
                <MudText Typo="Typo.h6" Style="font-weight: 700; color: var(--text-primary); margin-bottom: 20px;">
                    اجراءات سريعة
                </MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Outlined" FullWidth="true"
                                   Color="Color.Primary" Href="/invoices/create"
                                   Style="border-color: var(--border-gold); color: var(--primary-gold);">
                            فاتورة جديدة
                        </MudButton>
                    </MudItem>
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Outlined" FullWidth="true"
                                   Color="Color.Primary" Href="/customers/create"
                                   Style="border-color: var(--border-gold); color: var(--primary-gold);">
                            عميل جديد
                        </MudButton>
                    </MudItem>
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Outlined" FullWidth="true"
                                   Color="Color.Primary" Href="/inventory/create"
                                   Style="border-color: var(--border-gold); color: var(--primary-gold);">
                            منتج جديد
                        </MudButton>
                    </MudItem>
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Outlined" FullWidth="true"
                                   Color="Color.Primary" Href="/production/create"
                                   Style="border-color: var(--border-gold); color: var(--primary-gold);">
                            أمر إنتاج
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string _currentUsername = "User";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _currentUsername = user.Identity?.Name ?? "User";
    }
}
