@page "/login"
@layout LagalerieFurniture.Components.Layout.EmptyLayout
@using LagalerieFurniture.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>تسجيل الدخول - Lagalerie Furniture</PageTitle>

@* استدعاء الخطوط والأيقونات *@
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">

@* CSS Styles *@
<style>
    /* ================= التنسيق العام ================= */
    .split-login-container {
        display: flex;
        width: 100%;
        height: 100vh;
        overflow: hidden;
        direction: rtl;
        font-family: 'Cairo', sans-serif;
        background: #0b1120;
    }

    /* ================= الجانب الأيمن (النموذج) ================= */
    .login-side {
        width: 50%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 60px;
        position: relative;
        z-index: 10;
        overflow-y: auto;
        background: #0b1120;
    }

    .animated-bg {
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle at 50% 50%, rgba(108, 60, 225, 0.08) 0%, transparent 60%);
        animation: rotateBg 30s linear infinite;
        z-index: -1;
    }

    .noise-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
        opacity: 0.4;
        z-index: -1;
        pointer-events: none;
    }

    .login-wrapper {
        width: 100%;
        max-width: 440px;
        position: relative;
        animation: fadeInUp 0.8s ease-out;
    }

    /* الشعار */
    .mini-logo {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 40px;
    }
    .logo-icon {
        font-size: 2.2rem;
        color: #6C3CE1;
    }
    .logo-text {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: 1.8rem;
        color: #fff;
    }

    /* العناوين */
    .welcome-text h2 {
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 12px;
    }
    .welcome-text p {
        color: #94a3b8;
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: 40px;
    }

    /* الحقول */
    .form-group {
        position: relative;
        margin-bottom: 24px;
    }

    .input-field {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 14px;
        padding: 18px 50px 18px 20px;
        color: #fff;
        font-family: 'Cairo', sans-serif;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .input-field:focus {
        background: rgba(255, 255, 255, 0.08);
        border-color: #6C3CE1;
        box-shadow: 0 0 0 4px rgba(108, 60, 225, 0.15);
    }

    .input-label {
        position: absolute;
        right: 50px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 0.95rem;
        pointer-events: none;
        transition: all 0.3s ease;
        background: transparent;
        padding: 0 4px;
    }

    .input-field:focus + .input-label,
    .input-field:not(:placeholder-shown) + .input-label {
        top: 0;
        right: 15px;
        font-size: 0.75rem;
        color: #6C3CE1;
        background: #0b1120;
        border-radius: 4px;
        padding: 0 6px;
    }

    .input-icon {
        position: absolute;
        right: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 20px;
        transition: color 0.3s;
    }

    .input-field:focus ~ .input-icon {
        color: #6C3CE1;
    }

    .toggle-password {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 20px;
        cursor: pointer;
        transition: color 0.3s;
    }
    .toggle-password:hover {
        color: #fff;
    }

    /* الخيارات */
    .form-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        font-size: 0.9rem;
    }

    .remember-me {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #94a3b8;
        cursor: pointer;
    }
    .remember-me input {
        accent-color: #6C3CE1;
        width: 16px;
        height: 16px;
        cursor: pointer;
    }

    .forgot-pass {
        color: #6C3CE1;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s;
    }
    .forgot-pass:hover {
        color: #8B5CF6;
        text-decoration: underline;
    }

    /* الزر */
    .btn-submit {
        width: 100%;
        padding: 18px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg, #6C3CE1 0%, #8B5CF6 100%);
        color: #fff;
        font-family: 'Cairo', sans-serif;
        font-weight: 700;
        font-size: 1.1rem;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        box-shadow: 0 10px 30px -10px rgba(108, 60, 225, 0.5);
    }

    .btn-submit:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px -10px rgba(108, 60, 225, 0.7);
    }

    .btn-submit:disabled {
        background: #1e293b;
        color: #64748b;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .btn-loading {
        background: #1e293b;
    }

    .spinner {
        width: 20px;
        height: 20px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-top-color: #6C3CE1;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    /* رسالة الخطأ */
    .error-box {
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #fca5a5;
        padding: 14px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 0.9rem;
        animation: shake 0.4s ease-in-out;
    }

    /* حالة النظام */
    .system-status {
        margin-top: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-size: 0.8rem;
        color: #64748b;
        padding: 10px 20px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .status-dot {
        width: 8px;
        height: 8px;
        background-color: #10b981;
        border-radius: 50%;
        box-shadow: 0 0 10px #10b981;
        animation: pulse 2s infinite;
    }

    .copyright-text {
        text-align: center;
        margin-top: 24px;
        color: #475569;
        font-size: 0.8rem;
    }

    /* ================= الجانب الأيسر (الصور) ================= */
    .visual-side {
        width: 50%;
        position: relative;
        overflow: hidden;
        background: #000;
    }

    .slider-container {
        width: 100%;
        height: 100%;
        position: relative;
    }

    .slide {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        transition: opacity 1s ease-in-out;
    }

    .slide.active {
        opacity: 1;
    }

    .slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .slide-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to top, #0b1120 0%, rgba(11, 17, 32, 0.4) 50%, rgba(11, 17, 32, 0.2) 100%);
    }

    .slide-content {
        position: absolute;
        bottom: 100px;
        right: 60px;
        left: 60px;
        z-index: 2;
        color: #fff;
        transform: translateY(20px);
        opacity: 0;
        transition: all 0.8s ease-out 0.3s;
    }

    .slide.active .slide-content {
        transform: translateY(0);
        opacity: 1;
    }

    .slide-title {
        font-family: 'Playfair Display', serif;
        font-size: 3rem;
        margin-bottom: 16px;
        line-height: 1.1;
        color: #fff;
    }

    .slide-desc {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.8);
        max-width: 500px;
        border-right: 4px solid #6C3CE1;
        padding-right: 20px;
        line-height: 1.6;
    }

    .slider-indicators {
        position: absolute;
        bottom: 50px;
        left: 60px;
        display: flex;
        gap: 12px;
        z-index: 2;
    }

    .indicator {
        width: 40px;
        height: 3px;
        background: rgba(255, 255, 255, 0.2);
        cursor: pointer;
        transition: all 0.3s ease;
        border-radius: 2px;
    }

    .indicator.active {
        background: #6C3CE1;
        width: 60px;
    }

    .indicator:hover {
        background: rgba(255, 255, 255, 0.5);
    }

    /* Animations */
    @@keyframes rotateBg {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    @@keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
        100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateX(30px); }
        to { opacity: 1; transform: translateX(0); }
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-5px); }
        75% { transform: translateX(5px); }
    }

    /* Responsive */
    @@media (max-width: 992px) {
        .visual-side {
            display: none;
        }
        .login-side {
            width: 100%;
            padding: 40px 24px;
        }
        .login-wrapper {
            max-width: 100%;
        }
        .slide-title {
            font-size: 2rem;
        }
    }
</style>

<div class="split-login-container">
    
    @* ================= الجانب الأيمن: نموذج الدخول ================= *@
    <div class="login-side">
        <div class="animated-bg"></div>
        <div class="noise-overlay"></div>

        <div class="login-wrapper">
            @* الشعار *@
            <div class="mini-logo">
                <span class="material-icons-round logo-icon">chess_rook</span>
                <span class="logo-text">Lagalerie</span>
            </div>

            @* العناوين *@
            <div class="welcome-text">
                <h2>منصة الإدارة الموحدة</h2>
                <p>أهلاً بك في النظام المركزي لإدارة المعرض والمصنع</p>
            </div>

            @* الفورم *@
            <div class="form-container">
                @* رسالة الخطأ *@
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="error-box">
                        <span class="material-icons-round">error_outline</span>
                        <span>@_errorMessage</span>
                    </div>
                }

                @* حقل اسم المستخدم *@
                <div class="form-group">
                    <input type="text" 
                           @bind="_username" 
                           @bind:event="oninput"
                           class="input-field" 
                           placeholder=" " 
                           autocomplete="off" />
                    <label class="input-label">اسم المستخدم</label>
                    <span class="material-icons-round input-icon">person_outline</span>
                </div>

                @* حقل كلمة المرور *@
                <div class="form-group">
                    <input type="@_passwordInputType" 
                           @bind="_password" 
                           @bind:event="oninput"
                           class="input-field" 
                           placeholder=" " />
                    <label class="input-label">كلمة المرور</label>
                    <span class="material-icons-round input-icon">lock_outline</span>
                    <span class="material-icons-round toggle-password" @onclick="TogglePasswordVisibility">
                        @(_passwordInputType == "password" ? "visibility" : "visibility_off")
                    </span>
                </div>

                @* خيارات إضافية *@
                <div class="form-actions">
                    <label class="remember-me">
                        <input type="checkbox" @bind="_rememberMe" />
                        <span>تذكر هذا الجهاز</span>
                    </label>
                    <a href="#" class="forgot-pass">استعادة كلمة المرور؟</a>
                </div>

                @* زر الدخول *@
                @if (_isLoading)
                {
                    <button class="btn-submit btn-loading" disabled>
                        <div class="spinner"></div>
                        <span>جاري تأمين الاتصال...</span>
                    </button>
                }
                else
                {
                    <button class="btn-submit" @onclick="OnLoginAsync">
                        <span>دخول آمن</span>
                        <span class="material-icons-round">arrow_forward</span>
                    </button>
                }
            </div>

            @* حالة النظام *@
            <div class="system-status">
                <div class="status-dot"></div>
                <span>النظام يعمل • تشفير SSL 256-bit</span>
            </div>

            <div class="copyright-text">
                © @DateTime.Now.Year Lagalerie Furniture. جميع الحقوق محفوظة
            </div>
        </div>
    </div>

    @* ================= الجانب الأيسر: الصور المتغيرة ================= *@
    <div class="visual-side">
        <div class="slider-container">
            @* شريحة 1 *@
            <div class="slide @(currentSlide == 0 ? "active" : "")">
                <img src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?q=80&w=2000" alt="Furniture" />
                <div class="slide-overlay"></div>
                <div class="slide-content">
                    <h3 class="slide-title">فخامة التصميم</h3>
                    <p class="slide-desc">ندير كل تفاصيل العرض بدقة متناهية لضمان تجربة عميل استثنائية</p>
                </div>
            </div>
            
            @* شريحة 2 *@
            <div class="slide @(currentSlide == 1 ? "active" : "")">
                <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=2000" alt="Factory" />
                <div class="slide-overlay"></div>
                <div class="slide-content">
                    <h3 class="slide-title">دقة التصنيع</h3>
                    <p class="slide-desc">متابعة خطوط الإنتاج والجودة لحظياً من خلال لوحة التحكم</p>
                </div>
            </div>

            @* شريحة 3 *@
            <div class="slide @(currentSlide == 2 ? "active" : "")">
                <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2000" alt="Office" />
                <div class="slide-overlay"></div>
                <div class="slide-content">
                    <h3 class="slide-title">إدارة متكاملة</h3>
                    <p class="slide-desc">حلول برمجية تربط بين المخزون والمبيعات بكفاءة</p>
                </div>
            </div>

            @* مؤشرات الشرائح *@
            <div class="slider-indicators">
                <div class="indicator @(currentSlide == 0 ? "active" : "")" @onclick="@(() => SetSlide(0))"></div>
                <div class="indicator @(currentSlide == 1 ? "active" : "")" @onclick="@(() => SetSlide(1))"></div>
                <div class="indicator @(currentSlide == 2 ? "active" : "")" @onclick="@(() => SetSlide(2))"></div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _errorMessage = string.Empty;
    private bool _isLoading = false;
    private bool _rememberMe = false;
    private string _passwordInputType = "password";
    private int currentSlide = 0;
    private System.Timers.Timer? _slideTimer;

    protected override void OnInitialized()
    {
        // تشغيل السلايدر تلقائياً كل 5 ثواني
        _slideTimer = new System.Timers.Timer(5000);
        _slideTimer.Elapsed += (s, e) => InvokeAsync(() => NextSlide());
        _slideTimer.AutoReset = true;
        _slideTimer.Enabled = true;
    }

    private void NextSlide()
    {
        currentSlide = (currentSlide + 1) % 3;
        StateHasChanged();
    }

    private void SetSlide(int index)
    {
        currentSlide = index;
    }

    private void TogglePasswordVisibility()
    {
        _passwordInputType = _passwordInputType == "password" ? "text" : "password";
    }

    private async Task OnLoginAsync()
    {
        if (_isLoading) return;

        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            _errorMessage = "يرجى إدخال اسم المستخدم وكلمة المرور";
            return;
        }

        _errorMessage = string.Empty;
        _isLoading = true;

        try
        {
            var (success, errorMessage, username, role) = await AuthService.LoginAsync(_username, _password);

            if (success)
            {
                // forceLoad: true ضروري لإعادة تهيئة الـ circuit بعد إصدار الـ cookie
                // عشان يقرأ حالة المصادقة الجديدة من الـ HTTP request
                Navigation.NavigateTo("/", true);
            }
            else
            {
                _errorMessage = errorMessage ?? "اسم المستخدم أو كلمة المرور غير صحيحة";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"حدث خطأ: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose()
    {
        _slideTimer?.Stop();
        _slideTimer?.Dispose();
    }
}