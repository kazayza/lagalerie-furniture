@page "/roles"
@using LagalerieFurniture.Models
@using LagalerieFurniture.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components
@attribute [Authorize(Policy = "SET_VIEW")]
@inject IRoleService RoleService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>الأدوار - Lagalerie</PageTitle>

<div class="page-title-section">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.Shield" Class="text-gold" />
        إدارة الأدوار
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="page-subtitle">
        الأدوار ومجموعات الصلاحيات الممنوحة لكل دور
    </MudText>
</div>

<div class="filter-panel d-flex justify-space-between align-center">
    <div class="dashboard-panel-title" style="margin: 0;">
        <MudIcon Icon="@Icons.Material.Filled.List" Color="Color.Primary" />
        قائمة الأدوار
        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">@_roles.Count إجمالي</MudChip>
    </div>
    @if (_currentUser.HasPermission("SET_EDIT"))
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => Navigation.NavigateTo("/roles/new"))">
            دور جديد
        </MudButton>
    }
</div>

<div class="dashboard-panel">
    <div style="padding: 0;">
        @if (_loading)
        {
            <div style="padding: 32px;">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="skeleton" style="height: 64px; margin-bottom: 8px;"></div>
                }
            </div>
        }
        else
        {
            <MudTable Items="@_roles" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>اسم الدور</MudTh>
                    <MudTh>الوصف</MudTh>
                    <MudTh>النوع</MudTh>
                    <MudTh>المستخدمون</MudTh>
                    <MudTh>الحالة</MudTh>
                    <MudTh Style="text-align: center;">إجراءات</MudTh>
                </HeaderContent>
                <RowTemplate Context="r">
                    <MudTd>
                        <div class="d-flex align-center gap-2">
                            <div class="kpi-icon" style="width: 36px; height: 36px; background: var(--primary-gold-soft); color: var(--primary-gold);">
                                <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" />
                            </div>
                            <div>
                                <MudText Typo="Typo.body2" Style="color: var(--text-primary); font-weight: 600;">@r.DisplayName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">@r.Name</MudText>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd><MudText Typo="Typo.body2" Color="Color.Secondary">@(r.Description ?? "—")</MudText></MudTd>
                    <MudTd>
                        @if (r.IsSystem)
                        {
                            <span class="status-chip system">نظام</span>
                        }
                        else
                        {
                            <span class="status-chip custom">مخصّص</span>
                        }
                    </MudTd>
                    <MudTd>
                        <MudChip T="int" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">@GetUserCount(r.Id)</MudChip>
                    </MudTd>
                    <MudTd>
                        <span class="status-chip @(r.IsActive ? "active" : "disabled")">@(r.IsActive ? "نشط" : "معطّل")</span>
                    </MudTd>
                    <MudTd Style="text-align: center;">
                        @if (_currentUser.HasPermission("SET_EDIT"))
                        {
                            <MudTooltip Text="إدارة الصلاحيات">
                                <MudIconButton Icon="@Icons.Material.Filled.Security" Color="Color.Primary"
                                               OnClick="@(() => Navigation.NavigateTo($"/roles/{r.Id}/edit"))" />
                            </MudTooltip>
                        }
                        @if (_currentUser.HasPermission("SET_EDIT") && !r.IsSystem)
                        {
                            <MudTooltip Text="حذف">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => Delete(r))" />
                            </MudTooltip>
                        }
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="empty-state">
                        <MudIcon Icon="@Icons.Material.Filled.Shield" Class="empty-state-icon" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">لا توجد أدوار</MudText>
                    </div>
                </NoRecordsContent>
            </MudTable>
        }
    </div>
</div>

@code {
    private ClaimsPrincipal _currentUser = new();
    private int _currentUserId;
    private List<Role> _roles = new();
    private bool _loading = true;
    private readonly Dictionary<int, int> _userCountMap = new();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUser = state.User;
        _currentUserId = _currentUser.GetUserId() ?? 0;

        _loading = true;
        try
        {
            _roles = await RoleService.GetAllAsync();
            foreach (var r in _roles)
            {
                var details = await RoleService.GetDetailsAsync(r.Id);
                _userCountMap[r.Id] = details?.UsersCount ?? 0;
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private int GetUserCount(int roleId) => _userCountMap.GetValueOrDefault(roleId);

    private async Task Delete(Role r)
    {
        var parameters = new DialogParameters
        {
            ["Message"] = $"هل تريد حذف الدور «{r.DisplayName}»؟ لا يمكن التراجع عن هذا الإجراء.",
            ["YesText"] = "حذف",
            ["NoText"] = "إلغاء"
        };
        var dialog = await DialogService.ShowAsync<LagalerieFurniture.Components.Shared.ConfirmDialog>("تأكيد الحذف", parameters);
        var result = await dialog.Result;
        if (result?.Canceled ?? true) return;

        var (success, err) = await RoleService.DeleteAsync(r.Id, _currentUserId);
        if (success)
        {
            Snackbar.Add("تم الحذف", Severity.Success);
            _userCountMap.Remove(r.Id);
            _roles.RemoveAll(x => x.Id == r.Id);
            StateHasChanged();
        }
        else Snackbar.Add(err ?? "فشل", Severity.Error);
    }
}