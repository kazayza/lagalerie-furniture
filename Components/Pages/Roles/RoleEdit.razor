@page "/roles/new"
@page "/roles/{Id:int}/edit"
@using LagalerieFurniture.Models
@using LagalerieFurniture.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject IRoleService RoleService
@inject IPermissionService PermissionService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(_isEdit ? "تعديل دور" : "دور جديد") - Lagalerie</PageTitle>

<div class="page-title-section">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@(_isEdit ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)" Class="text-gold" />
        @(_isEdit ? "تعديل دور" : "دور جديد")
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="page-subtitle">
        بيانات الدور وصلاحياته على كل الموديولات
    </MudText>
</div>

@if (_loading)
{
    <div style="padding: 48px; text-align: center;">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </div>
}
else
{
    <div class="dashboard-panel mb-4">
        <div class="dashboard-panel-header">
            <div class="dashboard-panel-title">
                <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" />
                بيانات الدور
            </div>
        </div>
        <div class="dashboard-panel-body">
            <MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_displayName" Label="الاسم المعروض" Required="true"
                                  Variant="Variant.Outlined" />
                </MudItem>
                @if (!_isEdit)
                {
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_name" Label="المعرّف الفريد (Name)" Required="true"
                                      Variant="Variant.Outlined"
                                      HelperText="حروف إنجليزية بدون مسافات، مثل: SalesManager" />
                    </MudItem>
                }
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_description" Label="الوصف" Variant="Variant.Outlined" />
                </MudItem>
                @if (_isEdit)
                {
                    <MudItem xs="12">
                        <MudSwitch @bind-Value="_isActive" Label="الدور نشط" Color="Color.Success" />
                    </MudItem>
                }
            </MudGrid>
        </div>
    </div>

    @if (_isEdit)
    {
        <div class="dashboard-panel mb-4">
            <div class="dashboard-panel-header">
                <div class="dashboard-panel-title">
                    <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Warning" />
                    مصفوفة الصلاحيات
                    <MudChip T="int" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">
                        @_granted.Count(g => g.Value) / @_granted.Count مفعّل
                    </MudChip>
                </div>
                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.CheckCircle" OnClick="SelectAll">
                        تحديد الكل
                    </MudButton>
                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Cancel" OnClick="ClearAll">
                        مسح الكل
                    </MudButton>
                </div>
            </div>
            <div class="dashboard-panel-body" style="padding: 0;">
                @foreach (var moduleGroup in _matrixByModule)
                {
                    <div style="padding: 16px 20px; border-bottom: 1px solid var(--border-subtle);">
                        <div class="d-flex align-center gap-2 mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" Size="Size.Small" />
                            <MudText Typo="Typo.subtitle2" Style="color: var(--text-primary); font-weight: 700;">
                                @moduleGroup.Key.DisplayName
                            </MudText>
                        </div>
                        <MudTable Items="@moduleGroup" Hover="true" Elevation="0" Dense="true" Style="background: transparent;">
                            <HeaderContent>
                                <MudTh>الصلاحية</MudTh>
                                <MudTh>الفئة</MudTh>
                                <MudTh Style="text-align: center;">الكود</MudTh>
                                <MudTh Style="text-align: center;">ممنوحة</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="p">
                                <MudTd><MudText Typo="Typo.body2">@p.DisplayName</MudText></MudTd>
                                <MudTd><MudText Typo="Typo.caption" Color="Color.Secondary">@(p.Category ?? "—")</MudText></MudTd>
                                <MudTd Style="text-align: center;">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">@p.Code</MudText>
                                </MudTd>
                                <MudTd Style="text-align: center;">
                                    <MudCheckBox @bind-Value="@_granted[p.Code]" Color="Color.Primary" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                }
            </div>
        </div>
    }

    <div class="d-flex justify-end gap-2 mb-4">
        <MudButton Variant="Variant.Text" OnClick="@(() => Navigation.NavigateTo("/roles"))">إلغاء</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save"
                   StartIcon="@Icons.Material.Filled.Save">حفظ</MudButton>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private bool _isEdit => Id > 0;
    private bool _loading = true;

    private string _displayName = string.Empty;
    private string _name = string.Empty;
    private string? _description;
    private bool _isActive = true;

    private List<Permission> _allPerms = new();
    private IGrouping<Module, Permission>[] _matrixByModule = Array.Empty<IGrouping<Module, Permission>>();
    private Dictionary<string, bool> _granted = new(StringComparer.OrdinalIgnoreCase);
    private int _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = state.User.GetUserId() ?? 0;

        if (_isEdit)
        {
            var details = await RoleService.GetDetailsAsync(Id);
            if (details == null) { Snackbar.Add("الدور غير موجود", Severity.Error); Navigation.NavigateTo("/roles"); return; }
            _displayName = details.DisplayName;
            _name = details.Name;
            _description = details.Description;
            _isActive = details.IsActive;
        }

        _allPerms = await PermissionService.GetAllPermissionsAsync();
        _matrixByModule = _allPerms.GroupBy(p => p.Module).ToArray();

        if (_isEdit)
        {
            var details = await RoleService.GetDetailsAsync(Id);
            foreach (var p in _allPerms)
                _granted[p.Code] = details!.GrantedPermissionCodes.Contains(p.Code);
        }
        else
        {
            foreach (var p in _allPerms) _granted[p.Code] = false;
        }

        _loading = false;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_displayName))
        {
            Snackbar.Add("الاسم المعروض مطلوب", Severity.Warning);
            return;
        }

        if (_isEdit)
        {
            var (ok, err) = await RoleService.UpdateAsync(new UpdateRoleDto
            {
                Id = Id, DisplayName = _displayName, Description = _description, IsActive = _isActive
            }, _currentUserId);
            if (!ok) { Snackbar.Add(err ?? "فشل", Severity.Error); return; }

            var codes = _granted.Where(kv => kv.Value).Select(kv => kv.Key).ToHashSet();
            var (ok2, err2) = await RoleService.SetPermissionsAsync(Id, codes, _currentUserId);
            if (ok2) { Snackbar.Add("تم حفظ الدور وصلاحياته", Severity.Success); Navigation.NavigateTo("/roles"); }
            else Snackbar.Add(err2 ?? "فشل حفظ الصلاحيات", Severity.Error);
        }
        else
        {
            if (string.IsNullOrWhiteSpace(_name))
            {
                Snackbar.Add("المعرّف الفريد مطلوب", Severity.Warning);
                return;
            }
            var (ok, err, newId) = await RoleService.CreateAsync(new CreateRoleDto
            {
                Name = _name.Trim(), DisplayName = _displayName.Trim(), Description = _description
            }, _currentUserId);
            if (!ok) { Snackbar.Add(err ?? "فشل", Severity.Error); return; }
            Snackbar.Add("تم إنشاء الدور. وجّه لتعديل الصلاحيات.", Severity.Success);
            Navigation.NavigateTo($"/roles/{newId}/edit");
        }
    }

    private void SelectAll()
    {
        foreach (var p in _allPerms) _granted[p.Code] = true;
    }
    private void ClearAll()
    {
        foreach (var p in _allPerms) _granted[p.Code] = false;
    }
}